---
const { pathname } = Astro.url;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
];
---

<header class="border-b border-black/10 bg-white/80 backdrop-blur">
  <div class="max-w-3xl md:max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between gap-6">
    <a href="/" class="flex items-baseline gap-2 group" aria-label="Nathaniel Senyo Gemegah home">
      <span class="font-heading text-lg tracking-wide uppercase">
        Nathaniel Senyo Gemegah
      </span>
      <span class="hidden sm:inline-block text-xs font-body uppercase tracking-[0.2em] text-black/60 group-hover:text-black">
        Portfolio
      </span>
    </a>
    <nav aria-label="Main navigation">
      <ul class="flex items-center gap-4 sm:gap-6 text-xs sm:text-sm font-body uppercase tracking-[0.16em]">
        {navItems.map((item) => {
          const isActive = item.href === '/'
            ? pathname === '/'
            : pathname.startsWith(item.href);
          return (
            <li>
              <a
                href={item.href}
                class={[
                  'relative pb-1 transition-colors',
                  isActive ? 'text-violentRed' : 'text-black/70 hover:text-black',
                ]
                  .filter(Boolean)
                  .join(' ')}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
                <span
                  class={[
                    'absolute left-0 -bottom-0.5 h-[2px] w-full bg-violentRed transition-opacity',
                    isActive ? 'opacity-100' : 'opacity-0 group-hover:opacity-100',
                  ]
                    .filter(Boolean)
                    .join(' ')}
                />
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

