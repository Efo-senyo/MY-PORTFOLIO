---
const { compact } = Astro.props ?? {};
---

<section class={compact ? 'space-y-4' : 'space-y-6'}>
  <div class="space-y-2">
    <h2 class="section-heading">
      Join the Weekly Newsletter
    </h2>
    <p class="text-sm sm:text-base text-black/80 max-w-xl">
      Placeholder copy: briefly explain what subscribers can expect here&mdash;ideas, lessons, and behind-the-scenes updates from Pete.
    </p>
  </div>

  <form
    class="flex flex-col sm:flex-row gap-3 sm:gap-4 max-w-xl"
    method="post"
    action="#"
    aria-label="Join the weekly newsletter (placeholder form)"
  >
    <label class="flex-1">
      <span class="sr-only">Email address</span>
      <input
        type="email"
        name="email"
        required
        placeholder="you@example.com"
        class="w-full rounded-full border border-black/40 px-4 py-2.5 text-sm sm:text-base font-body placeholder-black/40 focus:outline-none focus:ring-2 focus:ring-violentRed focus:border-violentRed bg-white"
      />
    </label>
    <button
      type="submit"
      class="btn-primary w-full sm:w-auto"
    >
      Subscribe
    </button>
  </form>

  <p class="text-xs text-black/60 max-w-xl">
    This is a placeholder form only. Connect it to your email provider later.
  </p>
</section>

